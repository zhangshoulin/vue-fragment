{
  "name": "@lin/vue-fragment",
  "version": "0.1.0",
  "description": "A wrapperless Fragment component for Vue 2.6 and later.",
  "keywords": [
    "vue",
    "vue2",
    "fragment",
    "component"
  ],
  "license": "MIT",
  "author": "Lin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangshoulin/vue-fragment.git"
  },
  "bugs": {
    "url": "https://github.com/zhangshoulin/vue-fragment/issues"
  },
  "homepage": "https://github.com/zhangshoulin/vue-fragment#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "npm run clean && npm run build:types && rollup -c",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "vue": ">=2.6.0 <3"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "18.19.120",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "jsdom": "22.1.0",
    "prettier": "3.6.2",
    "rimraf": "5.0.10",
    "rollup": "4.62.1",
    "tslib": "2.8.1",
    "typescript": "5.9.2",
    "vite": "6.4.3",
    "vitest": "3.2.7",
    "vue": "2.6.14"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
